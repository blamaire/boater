APP_NAME=RZVG
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=nl
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=nl_NL

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Mediabibliotheek — 'local' voor storage/app/public/media, of 's3' voor een
# S3-compatible object-store (MEDIA_S3_* override AWS_*).
MEDIA_DISK=local

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Mail — verzending van transactionele e-mails (verificatie, wachtwoord-reset,
# toekomstige notificaties). Alle mails gaan via de queue
# (`QUEUE_CONNECTION=database`), dus de HTTP-request blokkeert niet op SMTP.
#
# Lokale ontwikkeling: de defaults hieronder wijzen naar Mailpit
# (http://localhost:8025) — geen configuratie nodig.
#
# Productie: overschrijf in het productie-`.env` één van de onderstaande
# provider-blokken. Zie `docs/mail-productie.md` voor de volledige uitleg
# (composer-package, DNS-records SPF/DKIM, test-commando).
#
#   Postmark (aanbevolen voor transactioneel):
#       MAIL_MAILER=postmark
#       POSTMARK_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
#   Mailgun:
#       MAIL_MAILER=mailgun
#       MAILGUN_DOMAIN=mg.rzvg.nl
#       MAILGUN_SECRET=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#       MAILGUN_ENDPOINT=api.eu.mailgun.net   # optioneel, EU-endpoint
#
#   Amazon SES:
#       MAIL_MAILER=ses
#       AWS_ACCESS_KEY_ID=
#       AWS_SECRET_ACCESS_KEY=
#       AWS_DEFAULT_REGION=eu-central-1
#
#   Resend:
#       MAIL_MAILER=resend
#       RESEND_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
#   Generieke SMTP (bijv. hosting-provider):
#       MAIL_MAILER=smtp
#       MAIL_HOST=smtp.jouwhost.nl
#       MAIL_PORT=587
#       MAIL_USERNAME=
#       MAIL_PASSWORD=
#       MAIL_ENCRYPTION=tls
#
# Zet nooit echte credentials in `.env.example` — alleen in het lokale `.env`.
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@rzvg.nl"
MAIL_FROM_NAME="Roei- en Zeilvereniging Gouda"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
