# Template voor de acceptatie-omgeving. Kopieer naar `.env.acc` in de acc-repo
# (bv. /var/www/rzvg-acc/.env.acc). Deze file staat in git; de echte `.env.acc`
# nooit.
#
# Zelfde regels als .env.tst.example: geen inline comments achter waardes,
# geen $, `, ", \ of # in wachtwoorden.

APP_NAME=RZVG
APP_ENV=production

# Vul met de output van:
#   docker run --rm php:8.4-cli php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;"
APP_KEY=

APP_CIPHER=aes-256-gcm

APP_DEBUG=false

# Publieke hostname van de acceptatie-omgeving (voor Laravel APP_URL).
APP_URL=https://rzvg-acc.lamaire.nl
APP_DOMAIN=rzvg-acc.lamaire.nl

# Dezelfde host als aparte var voor de gedeelde Caddy. De test-stack-caddy
# laadt dit `.env.acc`-bestand optioneel; alleen `ACC_DOMAIN` uit deze file
# wordt door Caddy gebruikt (APP_* wordt overschreven door `.env.tst`).
# Zie docker-compose.prod.yml en docker/caddy/Caddyfile.
ACC_DOMAIN=rzvg-acc.lamaire.nl

APP_LOCALE=nl
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=nl_NL

LOG_CHANNEL=stack
LOG_LEVEL=warning

# ---- Database (MySQL 8 container binnen de acc-stack) ----
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=rzvg_acc
DB_USERNAME=rzvg
# Kies iets sterks; alfanumeriek + `-_!.` — vermijd $, `, ", \ en #.
DB_PASSWORD=
DB_ROOT_PASSWORD=

# ---- Sessies / cache / queue ----
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# ---- Mail (optioneel op acc — kan naar dezelfde SMTP als test) ----
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=info@rzvg.lamaire.nl
MAIL_FROM_NAME="${APP_NAME} (acc)"

# ---- Media ----
MEDIA_DISK=local
FILESYSTEM_DISK=local

# ---- Vertrouwde proxies (Caddy uit test-stack zit ervoor) ----
TRUSTED_PROXIES=*

# ---- Multi-omgeving pagina-push ----
# Bearer-token die localhost/test moeten meesturen om naar acc te pushen.
# Genereer met: docker run --rm php:8.4-cli php -r "echo bin2hex(random_bytes(32)).PHP_EOL;"
RZVG_IMPORT_TOKEN=
