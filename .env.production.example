# Template voor de test/prod-server. Kopieer naar `.env` en vul in.
# Deze file staat in git; het echte `.env`-bestand nooit.
#
# BELANGRIJK: comments NIET achter een waarde plaatsen op dezelfde regel;
# dotenv leest ze als onderdeel van de waarde en levert een verkeerde
# APP_KEY / DB_PASSWORD op. Gebruik altijd een aparte comment-regel erboven.

APP_NAME=RZVG
APP_ENV=production

# Vul met de output van:
#   docker run --rm php:8.4-cli php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;"
APP_KEY=

# aes-256-gcm is de default in Laravel 12; expliciet zetten voorkomt
# dat een oude config-cache met AES-256-CBC blijft hangen.
APP_CIPHER=aes-256-gcm

APP_DEBUG=false

# Publieke hostname; wordt door Caddyfile ({$APP_DOMAIN}) en Laravel opgepikt.
APP_URL=https://rzvg-tst.lamaire.nl
APP_DOMAIN=rzvg-tst.lamaire.nl

APP_LOCALE=nl
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=nl_NL

LOG_CHANNEL=stack
LOG_LEVEL=warning

# ---- Database (MySQL 8 container) ----
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=rzvg
DB_USERNAME=rzvg
# Kies iets sterks; vermijd $, `, ", \ en # (dat botst met docker-compose
# variable-expansion of dotenv comment parsing).
DB_PASSWORD=
DB_ROOT_PASSWORD=

# ---- Sessies / cache / queue ----
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# ---- Mail (kies SMTP-provider) ----
MAIL_MAILER=smtp
# bv. smtp.postmarkapp.com
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=info@rzvg.lamaire.nl
MAIL_FROM_NAME="${APP_NAME}"

# ---- Media ----
MEDIA_DISK=local
FILESYSTEM_DISK=local

# ---- Vertrouwde proxies (Caddy zit ervoor) ----
TRUSTED_PROXIES=*

# ---- Multi-omgeving pagina-push ----
# Bearer-token dat andere RZVG-omgevingen moeten meesturen naar
# POST /api/pages/import. Alleen instellen op omgevingen die pushes
# accepteren (test/acceptatie/productie); genereer met bv.
#   docker run --rm php:8.4-cli php -r "echo bin2hex(random_bytes(32)).PHP_EOL;"
RZVG_IMPORT_TOKEN=
