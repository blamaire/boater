# Template voor de test/prod-server. Kopieer naar `.env` en vul in.
# Deze file staat in git; het echte `.env`-bestand nooit.

APP_NAME=RZVG
APP_ENV=production
APP_KEY=                              # Vul met `php artisan key:generate --show`
APP_DEBUG=false
# Publieke hostname; wordt door Caddyfile ({$APP_DOMAIN}) en Laravel opgepikt.
APP_URL=https://rzvg-tst.lamaire.nl
APP_DOMAIN=rzvg-tst.lamaire.nl

APP_LOCALE=nl
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=nl_NL

LOG_CHANNEL=stack
LOG_LEVEL=warning

# ---- Database (MySQL 8 container) ----
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=rzvg
DB_USERNAME=rzvg
DB_PASSWORD=                          # kies iets sterks
DB_ROOT_PASSWORD=                     # kies iets sterks

# ---- Sessies / cache / queue ----
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# ---- Mail (kies SMTP-provider) ----
MAIL_MAILER=smtp
MAIL_HOST=                            # bv. smtp.postmarkapp.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=info@rzvg.lamaire.nl
MAIL_FROM_NAME="${APP_NAME}"

# ---- Media ----
MEDIA_DISK=local
FILESYSTEM_DISK=local

# ---- Vertrouwde proxies (Caddy zit ervoor) ----
TRUSTED_PROXIES=*
